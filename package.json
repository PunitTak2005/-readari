{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cd frontend && npx vite --port=3001 --host=0.0.0.0",
    "start:frontend": "cd frontend && npx vite --port=3001 --host=0.0.0.0",
    "start:backend": "node backend/server.js",
    "dev:backend": "nodemon backend/server.js",
    "start": "npx concurrently \"npm run start:frontend\" \"npm run start:backend\"",
    "dev:all": "npx concurrently \"npm run start:frontend\" \"npm run dev:backend\"",
    "build": "cd frontend && npx vite build",
    "preview": "cd frontend && npx vite preview",
    "clean": "rm -rf frontend/dist",
    "lint": "echo 'Build validation passed!'"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.13.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "sqlite3": "^5.1.6",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "esbuild": "^0.25.0",
    "nodemon": "^3.1.14",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
